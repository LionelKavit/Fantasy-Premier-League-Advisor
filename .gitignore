# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cloned vaastav FPL dataset (external, large) — not part of the app
/historical_data

# Generated backtest artifacts (large)
research/composite-backtest/out/

# Fetched FPL data cache for squad-eval (28M of JSON — regenerate via fetch-cache.ts)
research/squad-eval/cache/

# Python + OS cruft
**/__pycache__/
**/.DS_Store

# Local-only Claude Code launch config
.claude/launch.json

# Demo video — too large to commit; upload via GitHub's web UI for an inline player
docs/images/*.mov
